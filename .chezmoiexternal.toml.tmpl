{{ if ne .chezmoi.os "windows" }}

[".oh-my-zsh"]
    type = "git-repo"
    url = "https://github.com/ohmyzsh/ohmyzsh.git"
[".oh-my-zsh/custom/themes/powerlevel10k"]
    type = "git-repo"
    url = "https://github.com/romkatv/powerlevel10k.git"
[".oh-my-zsh/custom/plugins/conda-zsh-completion"]
    type = "git-repo"
    url = "https://github.com/conda-incubator/conda-zsh-completion.git"
[".oh-my-zsh/custom/plugins/zsh-autosuggestions"]
    type = "git-repo"
    url = "https://github.com/zsh-users/zsh-autosuggestions.git"
[".oh-my-zsh/custom/plugins/fast-syntax-highlighting"]
    type = "git-repo"
    url = "https://github.com/zdharma-continuum/fast-syntax-highlighting.git"
[".config/kitty/kitty-themes"]
    type = "archive"
    url = "https://github.com/dexpota/kitty-themes/archive/1.0.0.tar.gz"
    exact = true
    stripComponents = 1
[".config/tmux/plugins/catppuccin/tmux"]
    type = "git-repo"
    url = "https://github.com/catppuccin/tmux.git"
    [".config/tmux/plugins/catppuccin/tmux".clone]
        args = ["-bv2.3.0"]
[".config/tmux/plugins/tmux-cpu"]
    type = "git-repo"
    url = "https://github.com/tmux-plugins/tmux-cpu.git"
[".config/tmux/plugins/tmux-battery"]
    type = "git-repo"
    url = "https://github.com/tmux-plugins/tmux-battery.git"

{{ end }}
