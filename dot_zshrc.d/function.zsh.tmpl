function chezmoi-sync() {
  source $COLOR_SCHEME_INCLUDE
  local action="$1"
  local repo="$HOME/.local/share/chezmoi"

{{- if eq .chezmoi.os "darwin" }}
# darwin
  local symbol='mac'
{{- else if and (eq .chezmoi.os "linux") (.chezmoi.kernel.osrelease | lower | contains "microsoft") }}
# wsl
  local symbol='wsl'
{{- else }}
# physical machine
  local symbol='arch'
{{- end }}

  case "$action" in
    pull)
      chezmoi git pull -- --autostash --rebase && chezmoi diff
    ;;
    push)
      git --git-dir="$repo/.git" --work-tree="$repo" add .
      git --git-dir="$repo/.git" --work-tree="$repo" commit \
        -m "Auto Sync ($symbol): $(date '+%Y-%m-%d %T')"

      if git --git-dir="$repo/.git" --work-tree="$repo" push origin main; then
        success "Chezmoi settings pushed to remote repository"
      else
        error "Something went wrong during push process"
      fi
    ;;
    *)
      error "Usage: chezmoi-sync [pull|push]"
    ;;
  esac
}
