# Description: Change to the directory output by yazi
function y() {
	local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
	yazi "$@" --cwd-file="$tmp"
	IFS= read -r -d '' cwd < "$tmp"
	[ -n "$cwd" ] && [ "$cwd" != "$PWD" ] && builtin cd -- "$cwd"
	rm -f -- "$tmp"
}

# Description: Enable | Disable the global proxy
function proxy() {
  source $COLOR_SCHEME_INCLUDE

  if [[ $1 == "on" ]]; then
    export http_proxy=http://127.0.0.1:7897
    export https_proxy=http://127.0.0.1:7897
    export all_proxy=socks5://127.0.0.1:7897
    success "Terminal proxy is now enabled"
  elif [[ $1 == "off" ]]; then
    unset http_proxy https_proxy all_proxy
    success "Terminal proxy is now disabled"
  else
    error "Usage: proxy [on|off]"
  fi
}

